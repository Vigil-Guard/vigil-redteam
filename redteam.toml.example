[api]
base_url = "https://your-guardrail.example.com"
verify_tls = true
timeout = 30

[runner]
# concurrency MUST equal rps — otherwise pipeline stalls
concurrency = 4
rps = 4
retries = 2
threshold = 40

[datasets]
golden_dir = "datasets/golden"
coverage_dir = "datasets/coverage"
mutation_dir = "datasets/mutation"

[reporting]
results_dir = "results"
reports_dir = "reports"
